NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/pt_app

# JWT
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# S3 / Media (use LocalStack for local dev)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=pt-app-media
S3_ENDPOINT=          # leave blank for AWS, or http://localhost:4566 for LocalStack

# CORS
FRONTEND_URL=http://localhost:5173
