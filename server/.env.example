# Copy this to .env and fill in values before running the server.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# Run `bash fix-postgres.sh` from project root to auto-populate this.
DATABASE_URL=postgresql://YOUR_USERNAME@localhost:5432/fittrack?host=/usr/local/var/run/postgresql

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 random characters. Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS (production only) ────────────────────────────────────────────────────
# Comma-separated list of allowed origins in production.
# Example: ALLOWED_ORIGINS=https://app.fittrack.com,https://fittrack.com
ALLOWED_ORIGINS=

# ── AWS S3 (media uploads) ────────────────────────────────────────────────────
# Leave empty for local dev — presign routes return stub URLs.
# In production, set all four values and uncomment the AWS SDK block in routes/media.js
AWS_REGION=us-east-1
AWS_BUCKET=fittrack-media
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
