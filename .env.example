# Frontend environment variables
# Copy this to .env (local) or .env.production (deployed) and fill in values.
#
# VITE_ vars are embedded in the JS bundle — do NOT put secrets here.

# ── API ───────────────────────────────────────────────────────────────────────
# Leave unset for local dev — Vite proxies /api → http://localhost:4000 automatically.
# In production, set this to your backend's base URL, e.g.:
#   https://your-app.fly.dev/api/v1
#   https://your-app.railway.app/api/v1
VITE_API_URL=
